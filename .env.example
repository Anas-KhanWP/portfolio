# Rename this file to .env.local and fill in your values.

# Your GitHub username (used to fetch repos)
GITHUB_USERNAME=your-github-username

# Upstash Redis (free tier: https://upstash.com)
# Get your REST URL and token from the Upstash console
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# GitHub Personal Access Token (optional, increases API rate limit to 5000/hr)
# https://github.com/settings/tokens
GITHUB_TOKEN=
